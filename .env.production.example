# Production runtime variables for Docker self-hosting.
# Copy this file to .env.production on the Linux server and fill only the real values there.

# Required runtime mode for Next.js standalone
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# DATABASE CONFIGURATION
# Choose one mode:
# 1) Recommended: set DATABASE_URL and keep the split variables as placeholders.
# 2) Or leave DATABASE_URL empty and fill DATABASE_HOST / DATABASE_PORT / DATABASE_NAME / DATABASE_USER / DATABASE_PASSWORD.

# Required if you use URL mode
DATABASE_URL=postgresql://dashboard_user:replace_me@postgres-host:5432/datalakehouse

# Required if you use split mode and DATABASE_URL is empty
DATABASE_HOST=postgres-host
DATABASE_PORT=5432
DATABASE_NAME=datalakehouse
DATABASE_USER=dashboard_user
DATABASE_PASSWORD=replace_me

# Optional but recommended when PostgreSQL requires TLS
DATABASE_SSL=false
